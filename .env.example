PORT=5000
NODE_ENV=development

JWT_SECRET=your_super_secret_jwt_key_change_this_in_production

# MongoDB (optional - falls back to in-memory storage if not set)
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/plansfer?retryWrites=true&w=majority

# Spotify API credentials (from Spotify Developer Dashboard)
SPOTIFY_CLIENT_ID=your_spotify_client_id
SPOTIFY_CLIENT_SECRET=your_spotify_client_secret
SPOTIFY_REDIRECT_URI=http://localhost:5000/api/spotify/callback

# Google/YouTube API credentials (from Google Cloud Console)
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_REDIRECT_URI=http://localhost:5000/api/youtube/callback

# Deezer API credentials (from Deezer Developer Portal)
DEEZER_APP_ID=your_deezer_app_id
DEEZER_SECRET_KEY=your_deezer_secret_key
DEEZER_REDIRECT_URI=http://localhost:5000/api/deezer/callback

# Google Gemini AI (from Google AI Studio)
GEMINI_API_KEY=your_gemini_api_key

#OpenAI API key
OPENAI_API_KEY=your_openai_api_key

FRONTEND_URL=http://localhost:5000
